# .gitignore

# 1. Core Production Static Build Output
# Never track the generated website folder, it is built on the fly
www/

# 2. Ruby Environment and Dependency Artifacts
.bundle/
vendor/bundle/
Gemfile.lock

# 3. Operating System and Local IDE Artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/

# 4. Container Architecture Cache Tracks
.dockerignore
